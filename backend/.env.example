# PaceVision backend configuration.
# All settings are optional; the defaults below match local development.
# Override via environment variables (prefix PACE_) in production.

# Comma-separated list of allowed frontend origins (CORS).
# In production set this to your deployed frontend, e.g.:
#   PACE_CORS_ORIGINS=https://your-app.vercel.app
PACE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Video analysis ──────────────────────────────────────────────────
# Max upload size (MB).
PACE_MAX_UPLOAD_MB=500
# Parallel video-processing workers (CPU-bound; keep small).
PACE_ANALYSIS_WORKERS=2
# Max jobs queued or processing at once (admission control).
PACE_MAX_ACTIVE_JOBS=8
# How long completed/failed jobs (and their temp files) are retained (sec).
PACE_JOB_TTL_SEC=3600
# Background cleanup sweep interval (sec).
PACE_CLEANUP_INTERVAL_SEC=300
# Timeout for the one-time MediaPipe model download (sec).
PACE_MODEL_DOWNLOAD_TIMEOUT_SEC=120

# ── MediaPipe detection ─────────────────────────────────────────────
PACE_MIN_DETECTION_CONFIDENCE=0.7
PACE_MIN_PRESENCE_CONFIDENCE=0.7
PACE_MIN_TRACKING_CONFIDENCE=0.7
